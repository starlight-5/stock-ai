# KIS OpenAPI 서버 주소
BASE_URL_REAL=https://openapi.koreainvestment.com:9443
BASE_URL_DEMO=https://openapivts.koreainvestment.com:29443

# ─────────────────────────────────────────────────
# KIS API 인증 정보 (절대 외부에 공유하지 마세요)
# ─────────────────────────────────────────────────
KIS_APP_KEY=여기
KIS_APP_SECRET=여기

# ─────────────────────────────────────────────────
# 계좌 및 사용자 정보
# ─────────────────────────────────────────────────
# 계좌번호 (앞 8자리)
KIS_ACCOUNT_NO=여기
# 계좌 상품코드 (01=종합위탁, 03=해외)
KIS_ACCOUNT_PRODUCT_CODE=여기
# KIS HTS 로그인 ID (실시간 체결통보 수신에 필요)
KIS_HTS_ID=여기

# ─────────────────────────────────────────────────
# 환경 설정
# ─────────────────────────────────────────────────
# 투자 환경: real=실전투자, demo=모의투자
KIS_ENV=demo